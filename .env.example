# ZECT Environment Configuration
# Copy this file to .env and fill in your values

# Login credentials
ZECT_USERNAME=admin
ZECT_PASSWORD=admin

# GitHub integration (for repo analysis, PR review)
GITHUB_TOKEN=

# AI features (code generation, review, planning)
OPENAI_API_KEY=

# Free AI models via OpenRouter
OPENROUTER_API_KEY=

# Jira integration
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# Slack notifications
SLACK_BOT_TOKEN=
